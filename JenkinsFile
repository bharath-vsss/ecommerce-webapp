@Library('my-shared-lib') _

pipeline {
    agent { label 'worker_node' } 

    environment {
        // Keeps reference variables localized
        IMAGE_NAME = 'studentapp'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    credentialsId: 'github_token', 
                    url: 'https://github.com/bharath-vsss/ecommerce-webapp.git'
            }
        }

        stage('Build & Extract Version') {
            steps {
                sh 'mvn clean install -DskipTests'
                script {
                    // Extracting exact project version from pom.xml
                    env.APP_VERSION = sh(script: "mvn help:evaluate -Dexpression=project.version -q -DforceStdout", returnStdout: true).trim()
                }
                echo "Detected Version: ${env.APP_VERSION}"
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${env.APP_VERSION} ."
            }
        }

        stage('Push to ECR & Deploy to K8s') {
            steps {
                // Unified to use 'aws-creds' to match your cloud environment credentials
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds'],
                    file(credentialsId: 'kubeconfig-self-managed', variable: 'KUBECONFIG_FILE')
                ]) {
                    script {
                        // Passing the application version and secret kubeconfig path into the shared library helper
                        awsHelpers(
                            appVersion: env.APP_VERSION, 
                            kubeconfigFile: env.KUBECONFIG_FILE
                        )
                    }
                }
            }
        }
    }

    post {
        always {
            // Cleans up local images and logs out to keep the worker node storage clean
            sh 'docker logout || true'
            sh "docker rmi ${IMAGE_NAME}:${env.APP_VERSION} || true"
            cleanWs()
        }
    }
}
